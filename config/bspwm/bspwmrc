#! /bin/sh

pgrep -x sxhkd >/dev/null || sxhkd &
pgrep -x dunst >/dev/null || dunst &
pgrep -x udiskie >/dev/null || udiskie --tray &

# --- env --------------------------
export XDG_CURRENT_DESKTOP='bspwm'
export _JAVA_AWT_WM_NONREPARENTING=1
# ----------------------------------

# ---compositor
picom --config ~/.config/picom/picom.conf &
# --------------

# ---copylist
greenclip daemon &
# -----------

# ---change language
setxkbmap -layout us,ru -option grp:alt_shift_toggle &
# -------------------

# --- wallpaper -----------------------
pkill -f "/home/dmytro/.config/bspwm/bin/script_select_background.py"
~/.config/bspwm/bin/script_select_background.py &
# -------------------------------------

# --- clolor
~/.config/bspwm/bin/script_color.py &
# ---------

# ---monitor
sleep 2

PRIMARY="$(xrandr --query | awk '/ primary/ {print $1; exit}')"
MONITORS="$(bspc query -M --names)"

if [ -n "$PRIMARY" ] && printf '%s\n' "$MONITORS" | grep -qx "$PRIMARY"; then
  ORDERED="$(printf '%s\n' "$PRIMARY" $(printf '%s\n' "$MONITORS" | grep -vx "$PRIMARY"))"
  bspc wm -O $(printf '%s ' $ORDERED)
else
  ORDERED="$MONITORS"
fi

COUNT="$(printf '%s\n' $ORDERED | sed '/^$/d' | wc -l)"

if [ "$COUNT" -eq 1 ]; then
  mon="$(printf '%s\n' "$ORDERED" | head -n1)"
  bspc monitor "$mon" -d 1 2 3 4 5 6
else
  start=1
  printf '%s\n' "$ORDERED" | while IFS= read -r mon; do
    [ -z "$mon" ] && continue
    bspc monitor "$mon" -d "$start" "$((start + 1))" "$((start + 2))"
    start=$((start + 3))
  done
fi
# ----------

# ---bar
killall -q polybar
while pgrep -x polybar >/dev/null; do sleep 0.5; done

for m in $(polybar --list-monitors | cut -d: -f1); do
  MONITOR="$m" polybar main &
done
# ------

# --- theme ------------------------------
bspc config border_width 2
bspc config window_gap 5
bspc config focused_border_color "#329DA4"
#bspc config normal_border_color "#000000"
#-----------------------------------------

bspc config split_ratio 0.52
bspc config borderless_monocle true
bspc config gapless_monocle true
